[control_plane]
control-plane ansible_host=203.0.113.10 private_ip=10.0.0.10 node_name=example-cluster-controlnode

[workers]
worker-1 ansible_host=203.0.113.11 private_ip=10.0.0.11 node_name=example-cluster-workernode1

[k3s_cluster:children]
control_plane
workers

[k3s_cluster:vars]
ansible_user=cc
ansible_ssh_private_key_file=~/.ssh/replace-with-your-private-key
cluster_name=example-cluster
k3s_token=replace-me
k3s_control_plane_ip=10.0.0.10
