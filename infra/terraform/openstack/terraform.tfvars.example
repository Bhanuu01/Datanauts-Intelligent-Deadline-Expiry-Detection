region                      = "KVM@TACC"
cluster_name                = "replace-me"
private_network_id          = "replace-with-your-private-network-uuid"
private_network_name        = "replace-with-your-private-network-name"
private_subnet_id           = "replace-with-your-private-subnet-uuid"
private_subnet_cidr         = "192.168.1.0/24"
external_network_name       = "public"
image_name                  = "CC-Ubuntu24.04"
ssh_keypair_name            = "replace-with-your-openstack-keypair-name"
ssh_private_key_path        = "~/.ssh/replace-with-your-local-private-key"
ssh_user                    = "cc"
ssh_allowed_cidr            = "0.0.0.0/0"
kubernetes_api_allowed_cidr = "0.0.0.0/0"
http_allowed_cidr           = "0.0.0.0/0"
https_allowed_cidr          = "0.0.0.0/0"
control_plane_lease_id      = "replace-with-your-control-plane-lease-id"
control_plane_reservation_id = "replace-with-your-control-plane-reservation-flavor-id"
worker_lease_id             = "replace-with-your-worker-lease-id"
worker_reservation_id       = "replace-with-your-worker-reservation-flavor-id"
enable_durable_block_storage = true
paperless_volume_size_gib    = 80
platform_volume_size_gib     = 80
ml_volume_size_gib           = 80
monitoring_volume_size_gib   = 40
paperless_volume_device      = "/dev/vdb"
platform_volume_device       = "/dev/vdc"
ml_volume_device             = "/dev/vdd"
monitoring_volume_device     = "/dev/vde"
bootstrap_object_storage_container = "replace-with-your-bootstrap-container-name"
